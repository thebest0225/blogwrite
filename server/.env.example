# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (.env 는 절대 공개 저장소에 올리지 마세요)

# KIE.ai (글/이미지) — 필수
KIE_API_KEY=
KIE_CHAT_MODEL=claude-sonnet-5
KIE_IMAGE_MODEL=gpt-image-2-text-to-image

# 네이버 검색 API (선택 · 링크 그라운딩용)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 워드프레스 직접 발행 (선택)
WP_SITE=
WP_USER=
WP_APP_PASSWORD=

# 서버 포트
PORT=3000
